  <!-- ── Actions ──────────────────────────────────────────────────────── -->
  <action name="actionLoadFolder">
   <property name="text">
    <string>📁  Load Folder…</string>
   </property>
   <property name="toolTip">
    <string>Load a folder — replaces current clips</string>
   </property>
  </action>
  <action name="actionAddFolder">
   <property name="text">
    <string>📂  Add Folder…</string>
   </property>
   <property name="toolTip">
